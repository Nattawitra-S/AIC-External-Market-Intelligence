# AIC ETL — MySQL Connection Settings
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git — it is in .gitignore.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=aic_user
MYSQL_PASS=your_password_here
MYSQL_DB=aic_market_intelligence

# Optional: staging directory for LOAD DATA CSV files
# Defaults to /tmp if not set
# MYSQL_STAGING_DIR=/tmp/aic_etl_staging
